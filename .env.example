# VoiceType Configuration Template
# Copy this file to .env and fill in your API keys
# 复制此文件为 .env 并填写你的 API 密钥
#
# 📝 开发者注意：
# - 首次运行前需下载模型: python scripts/download_models.py
# - 生产用户请使用打包版本（模型已内置）

# ========================================
# ASR Provider Selection
# ========================================
# Choose: sherpa (default, local offline) | aliyun | tencent
# 选择: sherpa（默认，本地离线）| aliyun | tencent
#
# 🆓 Sherpa-ONNX (推荐): 完全免费，隐私保护，离线可用
# ☁️ 云端 ASR: 更高准确率，支持方言和专业术语
ASR_PROVIDER=sherpa

# ========================================
# ASR - Sherpa-ONNX Local Offline (Default)
# 本地离线 ASR（默认）
# ========================================
# No API key required! Runs 100% locally.
# 无需 API Key！完全本地运行。
#
# Models will be auto-downloaded on first use (~60MB for bilingual)
# 首次使用时会自动下载模型（中英混合约60MB）
#
# Or manually download:
# 或手动下载：
#   python scripts/download_models.py --all
#
# Choose model | 选择模型:
#   - sherpa-onnx-streaming-zipformer-bilingual-zh-en-2023-02-20 (中英混合，530MB，默认)
SHERPA_MODEL_DIR=models/sherpa-onnx-streaming-zipformer-bilingual-zh-en-2023-02-20

# Features | 特性:
#   ✅ 100% local, no internet required | 完全本地，无需联网
#   ✅ Privacy-focused | 注重隐私
#   ✅ CPU-friendly (AMD Ryzen 7 5800H: ~20% CPU) | CPU 友好
#   ✅ Real-time streaming | 实时流式识别
#   ✅ Bilingual support (Chinese + English) | 中英混合支持

# Keyword Spotting (Wake Word) - Optional | 关键词唤醒（可选）:
SHERPA_KWS_ENABLED=false
SHERPA_KWS_MODEL_DIR=models/sherpa-onnx-kws-zipformer-wenetspeech-3.3M-2024-01-01
SHERPA_KEYWORDS=语音输入,开始输入  # Comma-separated | 逗号分隔

# ========================================
# ASR - Aliyun DashScope (Alternative, Higher Accuracy)
# 阿里云 DashScope（备选，更高准确率）
# ========================================
# Get API Key: https://dashscope.console.aliyun.com/apiKey
# Uncomment below to use Aliyun ASR for better accuracy
# 取消注释以下配置以使用阿里云 ASR（更高准确率）
#
# ASR_PROVIDER=aliyun
# ASR_API_KEY=your-aliyun-api-key-here
# ASR_MODEL=qwen3-asr-flash-realtime

# Optional: VAD (Voice Activity Detection) settings | VAD 设置（可选）
# ASR_MAX_SILENCE_MS=1200
#   Silence duration to end sentence (500-2000ms)
#   静音多久结束一句话（毫秒）
#
# ASR_VAD_THRESHOLD=0.5
#   Sensitivity (0.0-1.0, higher = less sensitive)
#   灵敏度（越高越不敏感）
#   Recommended: 0.5-0.7 for normal, 0.7-0.8 for noisy environment
#   推荐：0.5-0.7 正常环境，0.7-0.8 嘈杂环境

# ========================================
# ASR - Tencent Cloud (Alternative)
# 腾讯云（备选）
# ========================================
# Get Credentials: https://console.cloud.tencent.com/cam/capi
# Uncomment below to use Tencent Cloud ASR
# 取消注释以下配置以使用腾讯云 ASR
#
# ASR_PROVIDER=tencent
# ASR_API_KEY=your-tencent-secret-id-here
# ASR_SECRET_KEY=your-tencent-secret-key-here
# ASR_MODEL=16k_zh_en
#
# Recommended models | 推荐模型:
#   - 16k_zh_en (Chinese-English mix, recommended | 中英混合，推荐)
#   - 16k_zh (Pure Chinese | 纯中文)
#   - 16k_en (Pure English | 纯英文)

# ========================================
# LLM (OpenAI-compatible API) - Optional
# 大语言模型（OpenAI 兼容 API）- 可选
# ========================================
# Leave empty to skip LLM processing (faster but less cleanup)
# 留空则跳过 LLM 处理（速度更快但文本清理较少）
#
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo

# Optional: LLM advanced settings | LLM 高级设置（可选）
# LLM_TEMPERATURE=0.3
#   Temperature (0-2, default: 0.3)
#   温度（0-2，默认 0.3）
#   Lower = more deterministic, Higher = more creative
#   越低越确定，越高越有创造性
#
# LLM_MAX_TOKENS=200
#   Max output tokens (default: 200)
#   最大输出 token 数（默认 200）

# Examples for other LLM providers | 其他 LLM 厂商示例
#
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4
#
# DeepSeek:
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
#
# 智谱 GLM:
#   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   LLM_MODEL=glm-4-flash

# ========================================
# Input & Output Settings
# 输入输出设置
# ========================================
# Global hotkey to toggle recording (default: F9)
# 全局快捷键（默认 F9）
HOTKEY=<f9>

# Typing delay between characters in milliseconds (default: 5ms)
# 字符输出间隔（毫秒，默认 5ms）
TYPING_DELAY_MS=5

# ========================================
# Server Configuration
# 服务器配置
# ========================================
HOST=127.0.0.1
PORT=18233

# Auto-start recording when application launches
# 启动时自动开始录音
AUTO_START_ASR=false
