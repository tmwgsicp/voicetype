# VoiceType Configuration Template
# Copy this file to .env and fill in your API keys
# 复制此文件为 .env 并填写你的 API 密钥

# ========================================
# ASR Provider Selection
# ========================================
# Choose: aliyun (default) | tencent
# 选择: aliyun（默认）| tencent
ASR_PROVIDER=aliyun

# ========================================
# ASR - Aliyun DashScope (Default)
# 阿里云 DashScope（默认）
# ========================================
# Get API Key: https://dashscope.console.aliyun.com/apiKey
ASR_API_KEY=your-aliyun-api-key-here
ASR_MODEL=qwen3-asr-flash-realtime
# Optional: VAD silence threshold (ms), default: 1200
# 可选：VAD 静音阈值（毫秒），默认：1200
# ASR_MAX_SILENCE_MS=1200

# ========================================
# ASR - Tencent Cloud (Alternative)
# 腾讯云（备选）
# ========================================
# Get Credentials: https://console.cloud.tencent.com/cam/capi
# Uncomment below to use Tencent Cloud ASR
# 取消注释以下配置以使用腾讯云 ASR
#
# ASR_PROVIDER=tencent
# ASR_API_KEY=your-tencent-secret-id-here
# ASR_SECRET_KEY=your-tencent-secret-key-here
# ASR_MODEL=16k_zh
# Recommended models | 推荐模型:
#   - 16k_zh (Pure Chinese | 纯中文)
#   - 16k_zh_en (Chinese-English mix | 中英混合)
#   - 16k_en (Pure English | 纯英文)
# See docs/ASR_TENCENT_MODELS.md for full model list
# ASR_MAX_SILENCE_MS=1200

# ========================================
# LLM (OpenAI-compatible API)
# 大语言模型（OpenAI 兼容 API）
# ========================================
LLM_API_KEY=your-openai-compatible-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo

# ========================================
# RAG Knowledge Base (Local Qdrant)
# 知识库（本地 Qdrant 向量数据库）
# ========================================
# Qdrant data path (auto-managed, optional)
# QDRANT_STORAGE_PATH=          # Default: %APPDATA%/VoiceType/qdrant_data/
QDRANT_URL=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=voicetype-kb
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RAG_TOP_K=3
RAG_SCORE_THRESHOLD=0.6

# ========================================
# Input & Output Settings
# 输入输出设置
# ========================================
# Global hotkey to toggle recording
# 全局快捷键（F9 为默认）
HOTKEY=<f9>

# Typing delay between characters (ms)
# 字符输出间隔（毫秒）
TYPING_DELAY_MS=5

# ========================================
# Server Configuration
# 服务器配置
# ========================================
HOST=127.0.0.1
PORT=18233

# Auto-start recording when application launches
# 启动时自动开始录音
AUTO_START_ASR=false
